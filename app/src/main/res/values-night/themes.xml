<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RMMCStudentTaskHub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main Brand Colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary</item>

        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_primary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_primary</item>

        <item name="android:windowBackground">@color/surface_background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/card_stroke</item>

        <item name="android:statusBarColor">@color/surface_background</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
    </style>

    <style name="Theme.RMMCStudentTaskHub.NoActionBar" parent="Theme.RMMCStudentTaskHub">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
